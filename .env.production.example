APP_NAME=ScholarBridge
FLASK_APP=run.py
FLASK_ENV=production

# Required: set a long random value; do not use "change-me" in production.
SECRET_KEY=replace-with-strong-random-secret

# Required: local PostgreSQL on the EC2 host for pilot deployment.
DATABASE_URL=postgresql+psycopg://scholarbridge_app:replace-db-password@127.0.0.1:5432/scholarbridge

# Optional legacy reference only; not used as primary runtime DB in production.
SQLITE_DATABASE_URL=sqlite:///instance/scholarbridge.db

# Optional: override where generated letters/mailing lists are stored.
# GENERATED_LETTERS_DIR=/var/lib/scholarbridge/generated_letters
